    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background:#fefefe;color:#1e293b;line-height:1.6;}
    .container{max-width:1200px;margin:0 auto;padding:0 24px;}
    /* header */
    .site-header{background:#0a3d62;color:#fff;padding:16px 0;position:sticky;top:0;z-index:100;}
    .logo{font-size:1.6rem;font-weight:700;}
    .logo a{color:#fff;text-decoration:none;}
    /* hero */
    .hero{background:linear-gradient(135deg,#0a3d62,#1e5a7a);color:#fff;padding:60px 0;text-align:center;}
    .hero h1{font-size:2.5rem;margin-bottom:16px;}
    .hero p{font-size:1.2rem;max-width:800px;margin:0 auto;}
    /* content */
    .content{padding:48px 0;}
    h2{font-size:1.8rem;margin:40px 0 16px;border-left:5px solid #f39c12;padding-left:20px;}
    h3{font-size:1.4rem;margin:24px 0 12px;color:#0a3d62;}
    .service-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:24px;margin:32px 0;}
    .card{background:#fff;border-radius:16px;box-shadow:0 8px 20px rgba(0,0,0,0.08);padding:20px;transition:0.2s;border:1px solid #eef2f6;}
    .card:hover{transform:translateY(-4px);box-shadow:0 12px 24px rgba(0,0,0,0.12);}
    .card h3{margin-top:0;}
    .rating{color:#f39c12;margin:10px 0;font-weight:600;}
    .btn{display:inline-block;background:#f39c12;color:#fff;padding:10px 24px;border-radius:40px;text-decoration:none;font-weight:600;margin-top:12px;transition:0.2s;}
    .btn:hover{background:#e67e22;}
    .pro-tip{background:#eef2ff;border-left:4px solid #0a3d62;padding:20px;margin:32px 0;border-radius:12px;}
    .faq-item{border-bottom:1px solid #e2e8f0;padding:16px 0;}
    .faq-question{font-weight:700;font-size:1.1rem;cursor:pointer;display:flex;justify-content:space-between;}
    .faq-answer{max-height:0;overflow:hidden;transition:0.3s;color:#475569;}
    .faq-item.active .faq-answer{max-height:300px;margin-top:12px;}
    .cta-box{background:#0a3d62;color:#fff;padding:48px 24px;text-align:center;border-radius:24px;margin:48px 0;}
    .cta-box .btn{background:#f39c12;font-size:1.1rem;padding:12px 32px;}
    footer{background:#0f172a;color:#94a3b8;padding:40px 0;margin-top:48px;text-align:center;}
    @media(max-width:768px){.hero h1{font-size:1.8rem;}}
